generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String @id @default(cuid())
  email       String @unique
  username    String @unique
  passwordHash String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roomsHosted Room[] @relation("RoomHost")
  gamesHosted Game[] @relation("GameHost")
}

model Room {
  id         String   @id @default(cuid())
  code       String   @unique
  maxPlayers Int
  hostId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  host  User   @relation("RoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  games Game[]
}

model Game {
  id        String    @id @default(cuid())
  roomId    String
  hostId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  host User @relation("GameHost", fields: [hostId], references: [id], onDelete: Cascade)
}
